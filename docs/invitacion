<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Invitación de Matrimonio</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Montserrat:wght@300;400&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f8f6f1;
    font-family:'Montserrat',sans-serif;
}

.portada{
    min-height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    position:relative;
    overflow:hidden;
    background:
    radial-gradient(circle at top left,#f7f3ea 0%,#faf9f6 40%,#ffffff 100%);
}

/* FLORES */

.flor1,
.flor2,
.flor3,
.flor4{
    position:absolute;
    opacity:.95;
    pointer-events:none;
}

.flor1{
    top:0;
    left:0;
    width:220px;
}

.flor2{
    bottom:0;
    right:0;
    width:250px;
}

.flor3{
    top:40px;
    right:-20px;
    width:140px;
    opacity:.18;
}

.flor4{
    bottom:100px;
    left:-10px;
    width:160px;
    opacity:.18;
}

/* FOTO */

.foto-marco{
    width:220px;
    height:280px;
    border-radius:120px 120px 0 0;
    overflow:hidden;
    border:4px solid #c8b89a;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
    margin-bottom:35px;
}

.foto-marco img{
    width:100%;
    height:100%;
    object-fit:cover;
}

/* NOMBRES */

.nombres{
    font-family:'Cormorant Garamond',serif;
    font-size:2.4rem;
    color:#8c7961;
    letter-spacing:1px;
    margin-bottom:12px;
}

.fecha{
    color:#9d907d;
    letter-spacing:5px;
    margin-bottom:25px;
}

/* LINEA DECORATIVA */

.divisor{
    width:220px;
    height:1px;
    background:#c8b89a;
    position:relative;
    margin-bottom:35px;
}

.divisor::before,
.divisor::after{
    content:"✦";
    position:absolute;
    color:#b9a17d;
    top:-10px;
}

.divisor::before{
    left:-8px;
}

.divisor::after{
    right:-8px;
}

/* INVITADO */

.invitado{
    background:#f1ebdf;
    border:1px solid #d3c2a2;
    padding:18px 30px;
    border-radius:30px;
    margin-bottom:35px;
    max-width:90%;
}

.invitado span{
    display:block;
    font-size:.8rem;
    color:#9a8b75;
    letter-spacing:2px;
    margin-bottom:5px;
}

.invitado strong{
    font-family:'Cormorant Garamond',serif;
    font-size:1.6rem;
    color:#7c6b58;
}

/* BOTON */

.btn{
    text-decoration:none;
    color:#7c6b58;
    font-family:'Cormorant Garamond',serif;
    font-size:1.3rem;
    padding:14px 55px;
    border:2px solid #cbb99a;
    border-radius:40px;
    background:#efe6d5;
    transition:.3s;
}

.btn:hover{
    background:#d8c8ab;
    transform:translateY(-2px);
}

/* RESPONSIVE */

@media(max-width:768px){

    .foto-marco{
        width:180px;
        height:240px;
    }

    .nombres{
        font-size:1.9rem;
    }

    .flor1{
        width:160px;
    }

    .flor2{
        width:180px;
    }
}

</style>
</head>
<body>

<section class="portada">

    <!-- FLORES -->
    <img src="flores-esquina1.png" class="flor1">
    <img src="flores-esquina2.png" class="flor2">
    <img src="hojas.png" class="flor3">
    <img src="hojas.png" class="flor4">

    <!-- FOTO -->
    <div class="foto-marco">
        <img src="portada.jpg" alt="Novios">
    </div>

    <!-- NOMBRES -->
    <h1 class="nombres">
        Jhon & Bárbara
    </h1>

    <div class="fecha">
        27 • 06 • 2026
    </div>

    <div class="divisor"></div>

    <!-- INVITADO -->
    <div class="invitado">
        <span>INVITACIÓN PARA</span>
        <strong>Sr. Yesenia Quispe y Familia</strong>
    </div>

    <!-- BOTÓN -->
    <a href="#inicio" class="btn">
        Ingresar
    </a>

</section>

</body>
</html>